// Veille AO BTP — schéma de données
// Provider SQLite par défaut pour un démarrage local sans dépendance.
// Migration PostgreSQL : changer provider = "postgresql" et DATABASE_URL, puis `npx prisma db push`.
// Les champs *Json contiennent du JSON sérialisé (SQLite ne supporte ni enums ni tableaux natifs).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Source {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  kind           String // api | mock | rss
  implementation String // reelle | mockee
  status         String    @default("actif") // actif | en_erreur | partiellement_supporte | mocke
  enabled        Boolean   @default(true)
  cronExpression String
  timezone       String    @default("Europe/Paris")
  lastSuccessAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenders Tender[]
  runs    SyncRun[]
}

model Tender {
  id               String    @id @default(cuid())
  sourceId         String
  sourceRef        String // identifiant chez la source (ex: idweb BOAMP)
  dedupKey         String // hash normalisé titre+acheteur pour dédoublonnage inter-sources
  title            String
  buyer            String?
  description      String?
  cpvCodesJson     String    @default("[]")
  departementsJson String    @default("[]") // départements FR ou cantons CH selon country
  country          String    @default("FR") // FR | CH
  zonesJson        String    @default("[]") // ids des zones de veille correspondantes
  city             String?
  budgetEstime     Float?
  publishedAt      DateTime?
  deadlineAt       DateTime?
  procedureType    String?
  natureLibelle    String?
  sourceUrl        String?

  // Résultat du filtrage métier BTP
  score            Int    @default(0) // 0-100
  relevanceLevel   String @default("a_verifier") // tres_pertinent | pertinent | a_verifier | non_pertinent
  workCategory     String @default("hors_cible") // rehabilitation | renovation | gros_oeuvre | second_oeuvre | tce | maintenance_entretien | hors_cible
  keywordsJson     String @default("[]") // mots_cles_detectes
  justification    String?
  exclusionReason  String?
  scoredBy         String @default("rules") // ai | rules

  status    String   @default("new") // new | seen | archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  source        Source         @relation(fields: [sourceId], references: [id])
  notifications Notification[]

  @@unique([sourceId, sourceRef])
  @@index([dedupKey])
  @@index([score])
  @@index([deadlineAt])
}

model SyncRun {
  id           String    @id @default(cuid())
  sourceId     String
  trigger      String // cron | manual
  status       String    @default("running") // running | success | error
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  fetched      Int       @default(0)
  inserted     Int       @default(0)
  duplicates   Int       @default(0)
  rejected     Int       @default(0)
  alertsSent   Int       @default(0)
  errorMessage String?

  source Source @relation(fields: [sourceId], references: [id])

  @@index([sourceId, startedAt])
}

model Notification {
  id        String    @id @default(cuid())
  tenderId  String
  channel   String // email | slack
  status    String    @default("pending") // pending | sent | failed | skipped
  attempts  Int       @default(0)
  lastError String?
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  tender Tender @relation(fields: [tenderId], references: [id])

  // anti-doublon d'alertes : une seule notification par annonce et par canal
  @@unique([tenderId, channel])
}

model Setting {
  key       String   @id
  value     String // JSON sérialisé
  updatedAt DateTime @updatedAt
}

model ErrorLog {
  id        String   @id @default(cuid())
  scope     String // sync:boamp | notify:email | scheduler | ...
  message   String
  detail    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
